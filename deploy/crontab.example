# Cron for the English Home Libya platform. Install as /etc/cron.d/eh-platform
# (chmod 644).
#
# NOTE: content scheduling, comment automation, promotions and analytics run in
# the `worker` container — NO application cron is needed anymore. The only host
# job is the nightly backup.

# Nightly database + media backup (02:30).
30 2 * * * root /srv/eh-platform/scripts/backup.sh >> /var/log/eh-backup.log 2>&1
