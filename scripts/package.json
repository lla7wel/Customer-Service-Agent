{
  "name": "eh-system1-scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Operator tooling for the self-hosted platform: migrations, owner bootstrap, catalog family bootstrap, embeddings and image fingerprints.",
  "scripts": {
    "db:migrate": "tsx migrate.ts",
    "db:preflight": "tsx migrate.ts --preflight",
    "bootstrap:owner": "tsx bootstrap-owner.ts",
    "bootstrap:families": "tsx bootstrap-families.ts",
    "fingerprints": "tsx generate-image-fingerprints.ts",
    "embeddings": "tsx generate-embeddings.ts",
    "test:ai-control": "tsx ai-control-behavior-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jimp": "^1.6.1",
    "kysely": "^0.29.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
