# =============================================================================
# EH-SYSTEM1 — Environment Variables (template)
# =============================================================================
# Copy this file to `.env` (for scripts/workers) and to `admin-app/.env.local`
# (for the Next.js app). NEVER commit real secrets. See docs/ENV.md for details.
#
# The system is designed to RUN with these empty: every integration shows a
# clear "not connected / missing env var" state instead of faking data.
# =============================================================================

# --- Supabase (database, auth, storage) -------------------------------------
# Public values (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret (NEVER expose to the browser; used by scripts + server):
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket used for product + campaign images:
SUPABASE_STORAGE_BUCKET=eh-media

# Non-prefixed aliases used by scripts/workers (mirror the values above):
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Gemini (the ONLY AI provider) ------------------------------------------
GEMINI_API_KEY=
# ---------------------------------------------------------------------------
# MODEL ROUTING — every Gemini call is routed BY TASK (see docs/AI_BRAIN.md).
# The strong/expensive image model is ONLY used for actual image generation,
# never for text/classification/captions. All defaults verified available on
# the project key. Override only if you know why.
# ---------------------------------------------------------------------------
# 1) Customer-service text (Messenger replies, order wording, store/delivery):
GEMINI_TEXT_MODEL=gemini-2.5-flash
# 2) Intent / classification / routing / follow-up detection (cheapest):
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
# 3) Marketing copy (captions, Arabic headlines, design briefs) — text, not image:
GEMINI_MARKETING_TEXT_MODEL=gemini-2.5-flash
# 4) Vision (describe/compare customer product photos) — NOT image generation:
GEMINI_VISION_MODEL=gemini-2.5-flash
# 5) Embeddings ONLY (semantic vector search; verified GA model, 768 dims):
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768
# 6) Image generation / editing (strongest available — image work ONLY):
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_EDIT_MODEL=gemini-3-pro-image-preview
GEMINI_CAMPAIGN_IMAGE_MODEL=gemini-3-pro-image-preview
# Image fallback chain (used + logged + shown in admin if the primary is busy):
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_LAST_FALLBACK_MODEL=gemini-2.5-flash-image

# --- AI runtime flags -------------------------------------------------------
# Merge a burst of quick customer messages into ONE AI turn (default on).
# Debounce window in ms for batching (default 5000; clamped 1000-30000).
ENABLE_MESSAGE_BATCHING=true
MESSAGE_BATCH_WINDOW_MS=5000

# --- Meta / Facebook (Messenger + Page posting) -----------------------------
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
# Token YOU choose; Meta echoes it back during webhook verification:
META_VERIFY_TOKEN=
# App secret, used to verify X-Hub-Signature-256 on incoming webhooks:
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# --- Cloudflare / webhook workers -------------------------------------------
# Shared secret between the Next.js app and the Cloudflare Workers (cron/proxy):
CLOUDFLARE_WEBHOOK_SECRET=

# --- App config -------------------------------------------------------------
# Default admin UI language: "ar" (Libyan Arabic, RTL) or "en".
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_APP_NAME=EH-SYSTEM1
# Public base URL of the deployed admin app (used in webhook setup docs):
APP_BASE_URL=http://localhost:3000

# --- Local catalog-import scripts ONLY (not used by the production app) ------
# The deployed admin app no longer runs the scraper/import; these are only read
# by the optional `scripts/` workflow when an operator imports catalog data on
# their own machine. Safe to leave empty in production.
#   SCRAPER_OUTPUT_DIR / SCRAPER_IMAGES_DIR — scraper output the importer reads.
#   SCRAPER_DIR / CATALOG_CSV_PATH          — optional overrides for those paths.
SCRAPER_OUTPUT_DIR=../english-home-tr-scraper/data/output
SCRAPER_IMAGES_DIR=../english-home-tr-scraper/data/images
