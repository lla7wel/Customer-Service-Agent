# =============================================================================
# English Home Libya platform — environment template
# =============================================================================
# Copy to `.env` at the repo root. docker-compose reads it directly; for local
# dev, admin-app also loads it via Next.js env handling (or use direnv).
# The system runs with values missing: every integration shows a clear
# "not connected" state instead of faking data.
# =============================================================================

# --- Database ----------------------------------------------------------------
# docker-compose builds DATABASE_URL from these; for local dev set DATABASE_URL
# directly (e.g. postgres://localhost:5432/eh_system).
POSTGRES_DB=eh_system
POSTGRES_USER=eh
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Admin auth ----------------------------------------------------------------
# Single admin. Generate the hash:
#   node -e "require('bcryptjs').hash(process.argv[1],12).then(console.log)" 'your-password'
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# openssl rand -hex 32
SESSION_SECRET=

# --- Domains / URLs ------------------------------------------------------------
APP_DOMAIN=app.example.com
MEDIA_DOMAIN=media.example.com
APP_BASE_URL=https://app.example.com
PUBLIC_MEDIA_BASE_URL=https://media.example.com

# --- Media storage ---------------------------------------------------------------
# Filesystem root for product/campaign images (a Docker volume in production).
MEDIA_ROOT=/srv/eh-media

# --- Cron -----------------------------------------------------------------------
# Shared secret for /api/cron/campaign-scheduler (openssl rand -hex 24).
CRON_SECRET=

# --- Gemini (the only AI provider) -----------------------------------------------
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_MARKETING_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_LAST_FALLBACK_MODEL=gemini-2.5-flash-image
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# --- Meta / Facebook --------------------------------------------------------------
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_VERSION=v21.0

# --- Runtime flags ------------------------------------------------------------------
ENABLE_MESSAGE_BATCHING=true
MESSAGE_BATCH_WINDOW_MS=5000
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_APP_NAME=English Home Libya

# --- Local catalog scripts (never needed in production) ------------------------------
SCRAPER_OUTPUT_DIR=../english-home-tr-scraper/data/output
SCRAPER_IMAGES_DIR=../english-home-tr-scraper/data/images
CATALOG_CSV_PATH=../english-home-tr-scraper/data/input/catalog.csv
