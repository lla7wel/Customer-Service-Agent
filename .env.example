# =============================================================================
# English Home Libya platform — environment template
# =============================================================================
# Copy to `.env` at the repo root. docker-compose reads it directly; for local
# dev, admin-app also loads it via Next.js env handling.
# SAFE PLACEHOLDERS ONLY — never commit real values.
# =============================================================================

# --- Database ----------------------------------------------------------------
# docker-compose builds DATABASE_URL from these; for local dev set DATABASE_URL
# directly (e.g. postgres://localhost:5432/eh_system).
POSTGRES_DB=eh_system
POSTGRES_USER=eh
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Admin auth ----------------------------------------------------------------
# REQUIRED. The app fails closed (refuses to serve) without SESSION_SECRET.
#   openssl rand -hex 32
SESSION_SECRET=
# Owner bootstrap (first admin account). Generate the bcrypt hash locally:
#   node -e "require('bcryptjs').hash(process.argv[1],12).then(console.log)" 'your-password'
# Then run: cd scripts && npm run bootstrap:owner
OWNER_USERNAME=
OWNER_PASSWORD_HASH=

# --- Domains / URLs ------------------------------------------------------------
APP_DOMAIN=app.example.com
MEDIA_DOMAIN=media.example.com
APP_BASE_URL=https://app.example.com
PUBLIC_MEDIA_BASE_URL=https://media.example.com

# --- Media storage ---------------------------------------------------------------
# Filesystem root for product/content images (a Docker volume in production).
MEDIA_ROOT=/srv/eh-media

# --- Gemini (the only AI provider) -----------------------------------------------
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_ROUTER_MODEL=gemini-2.5-flash-lite
GEMINI_MARKETING_TEXT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
# Fast verifier used only for final Content Studio creatives. This reviews the
# already-rendered image; it never changes which model creates the output.
GEMINI_CREATIVE_VERIFICATION_MODEL=gemini-2.5-flash
# Final Content Studio creatives are pinned separately and never fall back.
GEMINI_CAMPAIGN_IMAGE_MODEL=gemini-3-pro-image
# Generic image tools may use their own model/fallback chain.
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_LAST_FALLBACK_MODEL=gemini-2.5-flash-image
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# --- Meta / Facebook / Instagram ---------------------------------------------------
# Page token needs: pages_messaging, pages_manage_posts, pages_read_engagement.
# Instagram additionally needs: instagram_basic, instagram_manage_messages,
# instagram_content_publish, instagram_manage_comments — and the IG business
# account linked to the Page. The in-app Settings → Channels check tells you
# exactly what is missing.
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
META_IG_USER_ID=
META_GRAPH_VERSION=v25.0

# --- Runtime flags ------------------------------------------------------------------
ENABLE_MESSAGE_BATCHING=true
MESSAGE_BATCH_WINDOW_MS=5000
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_APP_NAME=English Home Libya

# --- Local development only ----------------------------------------------------------
# Explicit auth bypass for local dev (ignored in production builds).
# AUTH_DISABLED_DEV=true

# --- Local catalog scripts (never needed in production) ------------------------------
SCRAPER_OUTPUT_DIR=../english-home-tr-scraper/data/output
SCRAPER_IMAGES_DIR=../english-home-tr-scraper/data/images
CATALOG_CSV_PATH=../english-home-tr-scraper/data/input/catalog.csv
